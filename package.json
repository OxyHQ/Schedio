{
  "name": "schedio",
  "version": "2.0.0",
  "description": "Schedio Monorepo - Frontend and Backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter '@schedio/frontend' dev",
    "dev:backend": "bun run --filter '@schedio/backend' dev",
    "build": "bun run --filter '*' build",
    "build:shared-types": "bun run --filter '@schedio/shared-types' build",
    "build:frontend": "bun run --filter '@schedio/frontend' build",
    "build:backend": "bun run --filter '@schedio/backend' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "install:all": "bun install",
    "start:frontend": "bun run --filter '@schedio/frontend' start",
    "start:backend": "bun run --filter '@schedio/backend' start",
    "web": "bun run --filter '@schedio/frontend' web",
    "postinstall": "bun run build:shared-types"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@oxyhq/bloom": "^0.9.1",
    "@oxyhq/core": "^3.6.0",
    "@oxyhq/services": "^10.3.3",
    "@react-native/js-polyfills": "^0.85.3",
    "react-native-worklets": "0.8.3",
    "react-native-worklets-core": "^1.6.3"
  },
  "overrides": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-secure-store": "56.0.4",
    "react-native-svg": "15.15.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/metro-babel-transformer": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@oxyhq/core": "3.6.0",
    "lightningcss": "1.30.1",
    "lightningcss-linux-x64-gnu": "1.30.1",
    "lightningcss-linux-x64-musl": "1.30.1"
  }
}
